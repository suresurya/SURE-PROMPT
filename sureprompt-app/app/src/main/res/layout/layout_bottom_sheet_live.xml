<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/md_theme_surface"
    android:padding="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="14dp"
        android:background="@color/md_theme_surface_variant" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI Sandbox Playground"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:textColor="@color/md_theme_on_surface" />

    <TextView
        android:id="@+id/tvLiveStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Powered by Google Gemini 1.5"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="@color/md_theme_on_surface_variant" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/code_surface_bg"
        app:cardCornerRadius="14dp"
        app:strokeColor="@color/md_theme_surface_variant"
        app:strokeWidth="1dp">

        <TextView
            android:id="@+id/tvLiveResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="150dp"
            android:padding="16dp"
            android:textColor="@color/code_surface_text"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:text="Waiting for execution..." />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Close Sandbox"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
